-- CTE: - Common Table expression
/* 
It is a expression used to created a temporary table for particular query.
-- It always starts with : --- > "WITH"

Types of CTEs:-
1. Normal CTE : - It contains where & order by clauses, select statements only
2. Aggreagted CTE: - It aggregated function and group by clauses
3. Complex CTE: - The queries can joined, can have aggreagte functions and also it can
				performal normal function


*/

use hr;

-- Create a CTE that lists all departments from EMP_SAL and display them. 

WITH dept_details as (
SELECT dept FROM emp_sal
) 
SELECT DISTINCT(DEPT) FROM dept_details;

-- Create a CTE to display employees who joined after 1-Jan-2012.

WITH jan_emp as (
SELECT * FROM emp
WHERE doj > "2012-01-01"
)
SELECT eid, name, city, email, doj FROM jan_emp;

-- Complex CTE write a query to find salaries greater than avg salary of dept.
WITH average as (
SELECT dept, AVG(salary) as "avg_salary" FROM emp_sal GROUP BY dept)
SELECT * FROM emp_sal s 
JOIN average a 
ON s.dept = a.dept
WHERE s.salary > a.avg_salary;

--  Use multiple CTEs to display employee details 
-- along with department-wise total salary

WITH emp_details as (
SELECT e.eid, e.name, e.city, e.email, s.dept, s.salary 
FROM emp e
JOIN emp_sal s
ON e.eid = s.eid
), -- A--------------------------------------
avg_salary_details as (
SELECT dept,  AVG(salary) as "avg_dept_sal" FROM emp_details GROUP BY dept
),-- B ----------------------------------------

final_output as (
SELECT d1.eid, d1.name, d1.city,d1.salary, d2.dept, d2.avg_dept_sal
FROM emp_details d1
JOIN avg_salary_details d2
ON d1.dept = d2.dept
)-- C------------------------------------------------------------

SELECT * FROM final_output;



