-- Create stored procdure in which you take input of dept and 
-- EID from user to increase their salary by 10%. 



delimiter //
CREATE PROCEDURE sal_inc(IN dept text, IN EID int)
BEGIN
	SET SQL_SAFE_UPDATES = 0;
	UPDATE emp_sal
    SET salary = salary + salary *0.10
    WHERE dept = dept AND eid = eid ;
END //
delimiter ;
	
    
