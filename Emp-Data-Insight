-- Type 3: - Store procedur with case:-
-- Write a stored procedure in which we will take input
-- from user of an eid and we will tell
-- whether the employee has low salary(<50000), 
-- medium salary(50000<=sal<=150000 or 
-- high salary(>150000).

USE hr;

delimiter //
CREATE PROCEDURE sal_category(IN emp_id INT)
BEGIN
    -- status code
    
SELECT salary as "salary",
		eid as "eid",
         
        CASE 
			WHEN salary< 50000 THEN "low"
            WHEN salary>=50000 and salary<=150000 THEN "medium"
            WHEN salary>150000 THEN "High"
            ELSE "employee not available"
		END as "Salary_status"
FROM emp_sal 
WHERE eid = emp_id;

END //
delimiter ;

CALL sal_category(1010);


    
