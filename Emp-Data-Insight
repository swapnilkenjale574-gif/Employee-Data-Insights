delimiter //
CREATE PROCEDURE insert_value(
IN emp_id INT,
IN emp_name VARCHAR(30),
IN ADDR1_ text,
IN ADDR2_ text,
IN city_ VARCHAR(20),
IN PH BIGINT,
IN email_ text,
IN d_birth DATE,
IN d_join DATE,
IN dept_ text,
IN desi_ text,
IN salary_ double
)
