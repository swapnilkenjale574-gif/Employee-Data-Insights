/*
Q2. Create a column "status_increment:" -  
1.  If a employee has low_salary and tenure>2 years
then increase his salary by 15%,
and mention status_increment = "Salary Inceased".

2.  If employee has mid_salary and tenure between 2 and 5 years 
then mention "Salary will be increased next month by 30%"

3.  if employee has high high_salary then mention 
"salary increased last month"
*/
WITH income_cat as (SELECT s.eid, s.salary, e.tenure,
CASE 
	WHEN salary <= 50000 THEN "Low_salary"
    WHEN salary > 50000 THEN "Mid_salary"
    WHEN salary >= 150000 THEN "High_Salary"
    ELSE "salary is not mentioned"
END 
AS "Salary_catgory"
FROM emp_sal s
JOIN emp e
ON s.eid = e.eid),
NEW_SAL AS (SELECT eid, (salary*0.15) as "new_sal", Salary_catgory
FROM income_cat
WHERE Salary_catgory = "Low_salary" OR TENURE < 2)
SELECT eid, new_sal, 
CASE 
	WHEN Salary_catgory = "low_salary" THEN "Salary increase 15%"
    WHEN Salary_catgory = "mid_salary" THEN "Salary will be increased next month by 30%"
    WHEN Salary_catgory = "high_salary" THEN "salary increased last month"
    ELSE "NO INCREMENT"
END as "increment_status"
FROM new_sal;



