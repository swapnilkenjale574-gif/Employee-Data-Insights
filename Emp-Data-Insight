-- 3. Find pairs of employees having the same designation.

SELECT e1.eid AS emp1_id, e1.name AS emp1_name, e2.eid AS emp2_id, e2.name AS emp2_name, s1.desi
FROM emp e1
JOIN emp_sal s1 ON e1.eid = s1.eid
JOIN emp_sal s2 ON s1.desi = s2.desi AND s1.eid < s2.eid
JOIN emp e2     ON s2.eid = e2.eid;

-- 4. Find pairs of employees who have the same salary.

SELECT e1.eid AS emp1_id, e2.eid AS emp2_id, s1.salary
FROM emp_sal s1
JOIN emp_sal s2 ON s1.salary = s2.salary AND s1.eid < s2.eid;


-- 5. Find pairs of employees who joined in the same year (use DOJ).

SELECT e1.eid AS emp1_id, e1.name AS emp1_name, e2.eid AS emp2_id, e2.name AS emp2_name, EXTRACT(YEAR FROM e1.doj) AS joining_year
FROM emp e1
JOIN emp e2 ON EXTRACT(YEAR FROM e1.doj) = EXTRACT(YEAR FROM e2.doj) AND e1.eid < e2.eid;


-- 6. Within each department, find employee pairs where one earns more than the other.

SELECT s1.dept, s1.eid AS higher_earner_id, s2.eid AS lower_earner_id, s1.salary AS higher_sal, s2.salary AS lower_sal
FROM emp_sal s1
JOIN emp_sal s2 ON s1.dept = s2.dept AND s1.salary > s2.salary;


-- 7. Find employee pairs who belong to the same city and same department.

SELECT e1.eid AS emp1_id, e2.eid AS emp2_id, e1.city, s1.dept
FROM emp e1
JOIN emp_sal s1 ON e1.eid = s1.eid
JOIN emp e2     ON e1.city = e2.city AND e1.eid < e2.eid
JOIN emp_sal s2 ON e2.eid = s2.eid AND s1.dept = s2.dept;


-- 8. Find pairs of employees in the same department where the salary difference is more than ₹50,000.

SELECT s1.dept, s1.eid AS emp1_id, s2.eid AS emp2_id, ABS(s1.salary - s2.salary) AS salary_diff
FROM emp_sal s1
JOIN emp_sal s2 ON s1.dept = s2.dept AND s1.eid < s2.eid
WHERE ABS(s1.salary - s2.salary) > 50000;


-- 9. Find employees who are not the highest paid in their department using a self join.

SELECT DISTINCT s1.eid, s1.dept, s1.salary
FROM emp_sal s1
JOIN emp_sal s2 ON s1.dept = s2.dept AND s1.salary < s2.salary;

-- 10. Find employees who earn more than the average salary of their own department using self join logic.

SELECT s1.eid, s1.dept, s1.salary
FROM emp_sal s1
JOIN (
    SELECT dept, AVG(salary) AS avg_sal
    FROM emp_sal
    GROUP BY dept
) dept_avg ON s1.dept = dept_avg.dept
WHERE s1.salary > dept_avg.avg_sal;



