USE hr;

-- Recurcive CTE
/*
This query which call itself until the specific condition met
*/

WITH RECURSIVE rec_roll (n)as (
	SELECT 1 AS n -- starting/ non-recursive
    UNION ALL   -- joining
    SELECT n+1 as n FROM rec_roll-- recursive
    WHERE n<10 
)
SELECT * FROM rec_roll
WHERE n%2=0;

-- Find the numbers from 1 - 50 which is completely divisible 3 and 5.

WITH RECURSIVE rec_roll (n)as (
	SELECT 1 AS n -- starting/ non-recursive
    UNION ALL   -- joining
    SELECT n+1 as n FROM rec_roll-- recursive
    WHERE n<50  
)
SELECT * FROM rec_roll
WHERE n%3=0 AND n%5=0;


